# Copy to .env in the repo root. Never commit .env.

# Used when vision naming is wired up.
ANTHROPIC_API_KEY=

# Optional. Default: claude-sonnet-4-20250514
# SNAPNAME_MODEL=

# Optional. Default: ~/Desktop
# SNAPNAME_SCREENSHOTS_DIR=

# Optional. Set to 1 to use polling instead of FSEvents (e.g. some sandboxes / VMs).
# SNAPNAME_POLLING=

# Optional. Default 1: only rename files whose name starts with "Screenshot". Set 0 for all images.
# SNAPNAME_ONLY_SCREENSHOT_PREFIX=

# Optional. Prepended / appended to generated base names.
# SNAPNAME_FILENAME_PREFIX=
# SNAPNAME_FILENAME_SUFFIX=
